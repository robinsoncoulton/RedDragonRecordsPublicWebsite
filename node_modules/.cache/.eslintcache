sages":"198","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},"/Users/robinsoncoulton/Code/studio/src/index.tsx",[],[],"/Users/robinsoncoulton/Code/studio/src/reportWebVitals.ts",[],[],[],"/Users/robinsoncoulton/Code/studio/src/App.tsx",[],[],"/Users/robinsoncoulton/Code/studio/src/Utils/routes.tsx",[],[],"/Users/robinsoncoulton/Code/studio/src/Components/Construction/index.tsx",[],[],"/Users/robinsoncoulton/Code/studio/src/Components/Construction/styles.tsx",[],[],"/Users/robinsoncoulton/Code/studio/src/Pages/Home/index.tsx",[],[],"/Users/robinsoncoulton/Code/studio/src/Components/Page/index.tsx",["199","200"],[],"/Users/robinsoncoulton/Code/studio/src/Components/Hero/index.tsx",["201","202","203","204","205","206"],[],"import React from 'react';\nimport { StyledHero, StyledIframe, CarouselContainer, CarouselCard, CarouselCardText } from './styles';\nimport heroImage from '../../Assets/placeholder.jpeg'\nimport valves from '../../Assets/valves.png';\nimport laney from '../../Assets/laney.png';\nimport quality from '../../Assets/quality.png';\nimport { Carousel } from 'react-responsive-carousel';\nimport \"react-responsive-carousel/lib/styles/carousel.min.css\";\n\n\nconst Hero:React.FC = () => \n    <Carousel \n        autoPlay={false} \n        showStatus={false}\n        showIndicators={false}\n        showThumbs={false}\n        infiniteLoop\n        interval={6000}>\n        <CarouselContainer>\n            <CarouselCard \n                horizontalOffsetType='right' \n                horizontalOffset='50'\n                verticalOffsetType='top'\n                verticalOffset='50'\n            >\n                <h1>Lovingly crafted using the finest ingredients</h1>\n                <hr></hr>\n                <p>\"If you want to make a rock and roll ommlette, you have to break some sound barriers\" <br />- Winston Churchill</p>\n            </CarouselCard>\n            <StyledIframe src='https://player.vimeo.com/video/813596415?api=1&player_id=video-iframe-1&html5=1&autopause=0&autoplay=1&badge=0&byline=0&loop=1&title=0&background=1&mute=1' />\n        </CarouselContainer>\n        <CarouselContainer>\n            <CarouselCard \n                horizontalOffsetType='left' \n                horizontalOffset='50'\n                verticalOffsetType='bottom'\n                verticalOffset='50'\n            >\n                <h1>The finest minds in the business</h1>\n                <hr></hr>\n                <p>\"Sometimes, you know... you have to...like.. you know.... come up with the song all by yourself...... you know.\" <br />- George W. Bush</p>\n            </CarouselCard>\n            <img src={valves} />\n        </CarouselContainer>\n        <CarouselContainer>\n            <CarouselCard \n                    horizontalOffsetType='left' \n                    horizontalOffset='50'\n                    verticalOffsetType='bottom'\n                    verticalOffset='500'\n                >\n                <h1>I spent all my money so that you dont have to</h1>\n                <hr></hr>\n                <p>\"This noise is actually quite soothing\" <br />- Marcus Aurelius</p>\n            </CarouselCard>\n            <img src={quality} />\n        </CarouselContainer>\n        <CarouselContainer>\n            <CarouselCard \n                    horizontalOffsetType='left' \n                    horizontalOffset='50'\n                    verticalOffsetType='top'\n                    verticalOffset='50'\n                >\n                <h1>For some reason I keep buying British built stuff.</h1>\n                <hr></hr>\n                <p>\"Yabadabadooooooooo\" <br />- Ghandi</p>\n            </CarouselCard>\n            <img src={laney} />\n        </CarouselContainer>\n    </Carousel>\n\nexport default Hero;","/Users/robinsoncoulton/Code/studio/src/Components/Page/styles.tsx",[],[],"/Users/robinsoncoulton/Code/studio/src/Components/Hero/styles.tsx",[],[],"/Use